{
  "//": "Per-project Claude Code settings. Copy to .claude/settings.json and edit.",
  "//permissions": "Allow the verify commands your project uses so agents don't prompt on every run. Keep this tight — only what the team actually needs.",
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test:*)",
      "Bash(npm run build)",
      "Bash(npx tsc --noEmit)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)"
    ]
  },
  "//env": "Optional environment variables for this project's sessions.",
  "env": {},
  "//hooks": "Optional event hooks. See templates/hooks/ for examples; paste a hook config here to enable it.",
  "hooks": {}
}
